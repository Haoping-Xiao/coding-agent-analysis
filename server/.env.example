# ===== AI 问答 + FAQ 后端环境变量 =====
# 全部留空时：后端进入「本地降级模式」——FAQ 用本地 SQLite 文件、代码走本地 vendors/、
# 问答走演示模式。配齐后即为生产形态。

# --- Cursor SDK（真实 AI 回答必需）---
# 取得：cursor.com → 登录 → Dashboard → Integrations / API Keys → 新建 key
CURSOR_API_KEY=
# 可选，模型 id（默认 auto）
CURSOR_MODEL=auto

# --- Turso / libSQL（FAQ 数据库；不配则用本地 file:faq.db）---
# 取得：turso.tech 注册 → 安装 turso CLI → `turso db create faq` → 见下
#   turso db show faq --url        → 填 TURSO_DATABASE_URL（libsql://...）
#   turso db tokens create faq     → 填 TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Cloudflare R2（代码仓虚拟文件系统；不配则直接读本地 vendors/）---
# 取得：Cloudflare 控制台 → R2 → 创建 bucket（记下名字）
#       R2 → Manage API Tokens → 创建 token（Object Read&Write）→ 拿到 Access Key/Secret
#       账号 ID 在 R2 概览页右侧
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 可选：直接给 S3 endpoint（不给则用 https://<account_id>.r2.cloudflarestorage.com）
R2_ENDPOINT=

# --- 其它 ---
PORT=8787
