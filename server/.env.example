# ===== AI 问答 + FAQ 后端环境变量 =====
# 全部留空：本地降级模式（FAQ 用本地 SQLite、agent 读本机 vendors/、问答走演示模式）。

# --- Cursor SDK（真实 AI 回答必需）---
# 取得：cursor.com → 登录 → Dashboard → API Keys / Integrations → 新建 key
CURSOR_API_KEY=
# 可选，模型 id（默认 auto）
CURSOR_MODEL=auto

# 运行时：local（默认，本机 cwd 读 vendors/，需本机有这份代码）
#         cloud（Cursor 起隔离 sandbox VM 把仓库 clone 进去，agent 在里面读代码——部署首选）
CURSOR_RUNTIME=local
# cloud 运行时要 clone 的仓库（GitHub，需已连接到你的 Cursor 团队）+ 分支
CURSOR_REPO_URL=
CURSOR_REPO_REF=main

# --- Turso / libSQL（FAQ 数据库；不配则用本地 file:faq.db）---
# 取得：turso.tech 注册 → 装 CLI → turso db create faq
#   turso db show faq --url     → TURSO_DATABASE_URL（libsql://...）
#   turso db tokens create faq  → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- 其它 ---
PORT=8787
